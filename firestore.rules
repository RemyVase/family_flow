rules_version = '2';

// Our Tribe — Firestore security rules.
// Philosophy (see .claude/rules/firestore-security.md):
//   - Default deny: nothing is accessible unless explicitly allowed.
//   - Data is scoped to its tribe: only members of a tribe can access it.
//   - Least privilege + validation on write.
// Every new collection MUST get its own match block here, in the same change.
//
// Data model:
//   users/{uid}                     — a user's own profile (firstName, email, tribeId)
//   tribes/{tribeId}                — the tribe (name, ownerId, inviteCode, color)
//   tribes/{tribeId}/members/{uid}  — membership, doc id == member uid
//   tribes/{tribeId}/tasks/{taskId} — the tribe's tasks
//   invites/{code}                  — public code → tribe lookup (tribeId, tribeName)

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // Helpers
    // -----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Is the signed-in user a member of this tribe?
    function isTribeMember(tribeId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tribes/$(tribeId)/members/$(request.auth.uid));
    }

    // The tribe document as it will exist after this write commits
    // (handles the creation batch where tribe + invite + member land together).
    function tribeAfter(tribeId) {
      return getAfter(/databases/$(database)/documents/tribes/$(tribeId));
    }

    // -----------------------------------------------------------------
    // users/{userId} — a user's own profile document. Owner-only.
    // -----------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.firstName is string
        && request.resource.data.email is string;
      allow update: if isOwner(userId);
      allow delete: if false; // account deletion handled server-side
    }

    // -----------------------------------------------------------------
    // invites/{code} — public lookup of an invite code.
    // `get` only (no `list`) so codes cannot be enumerated.
    // -----------------------------------------------------------------
    match /invites/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      // Created by the tribe owner in the tribe-creation batch.
      allow create: if isSignedIn()
        && request.resource.data.tribeId is string
        && tribeAfter(request.resource.data.tribeId).data.ownerId == request.auth.uid;
      // Member-count refresh after a join/leave.
      allow update: if isTribeMember(resource.data.tribeId)
        && request.resource.data.tribeId == resource.data.tribeId
        && request.resource.data.tribeName == resource.data.tribeName;
      // Deleted when the last member deletes the tribe.
      allow delete: if isTribeMember(resource.data.tribeId);
    }

    // -----------------------------------------------------------------
    // tribes/{tribeId} — the tribe and everything scoped to it.
    // -----------------------------------------------------------------
    match /tribes/{tribeId} {
      allow read: if isTribeMember(tribeId);
      allow update, delete: if isTribeMember(tribeId);

      // Creating a tribe: the creator must record themselves as owner and
      // declare the invite code the invite document is keyed by.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.inviteCode is string;

      // Membership documents (doc id == member uid).
      match /members/{memberId} {
        allow read: if isTribeMember(tribeId);

        // Two ways in, both self-only (a user can never enrol someone else):
        //   1. Founder bootstrap — the tribe lands in the same batch and
        //      names the caller as owner.
        //   2. Invited join — the member doc carries the joinCode field,
        //      which must resolve to this very tribe.
        allow create: if isOwner(memberId)
          && (
            tribeAfter(tribeId).data.ownerId == request.auth.uid
            || get(/databases/$(database)/documents/invites/$(request.resource.data.joinCode)).data.tribeId == tribeId
          );

        // Color, name, points and chief handover. Tribe-scoped rather than
        // self-only on purpose: completing a task credits the assignee's
        // counters, and the chief edits colors / hands the role over.
        allow update: if isTribeMember(tribeId);

        // Self-leave, or removal by the tribe's chief.
        allow delete: if isOwner(memberId)
          || (isTribeMember(tribeId)
            && get(/databases/$(database)/documents/tribes/$(tribeId)/members/$(request.auth.uid)).data.isChief == true);
      }

      // The tribe's tasks.
      match /tasks/{taskId} {
        allow read: if isTribeMember(tribeId);
        allow create: if isTribeMember(tribeId)
          && request.resource.data.name is string
          && request.resource.data.points is int;
        allow update, delete: if isTribeMember(tribeId);
      }
    }

    // -----------------------------------------------------------------
    // Default deny — anything not explicitly matched above is forbidden.
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
